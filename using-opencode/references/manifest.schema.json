{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OpenCode router manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["batch_id", "objective", "workdir", "artifact_root", "model", "tasks"],
  "properties": {
    "batch_id": {"type": "string", "minLength": 1},
    "objective": {"type": "string", "minLength": 1},
    "workdir": {"type": "string", "minLength": 1},
    "artifact_root": {"type": "string", "minLength": 1},
    "model": {"const": "opencode-go/deepseek-v4-flash"},
    "max_concurrency": {"type": "integer", "minimum": 1, "maximum": 128},
    "max_execution_workers": {"type": "integer", "minimum": 1, "maximum": 128},
    "max_audit_workers": {"type": "integer", "minimum": 1, "maximum": 128},
    "worker_timeout_seconds": {"type": "integer", "minimum": 1},
    "verification_timeout_seconds": {"type": "integer", "minimum": 1},
    "max_retries": {"type": "integer", "minimum": 0},
    "max_log_bytes": {"type": "integer", "minimum": 1024},
    "max_total_model_calls": {"type": "integer", "minimum": 1},
    "integration_auditors": {"type": "integer", "minimum": 1, "maximum": 4},
    "integration_verification": {"$ref": "#/$defs/stringArray"},
    "tasks": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/task"}}
  },
  "$defs": {
    "stringArray": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "objective", "read_scope", "write_scope", "exclusions", "actions", "deliverables", "acceptance_criteria", "verification", "stop_conditions"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
        "objective": {"type": "string", "minLength": 1},
        "risk": {"enum": ["low", "medium", "high", "critical"]},
        "read_scope": {"$ref": "#/$defs/stringArray"},
        "write_scope": {"$ref": "#/$defs/stringArray"},
        "exclusions": {"$ref": "#/$defs/stringArray"},
        "actions": {"$ref": "#/$defs/stringArray"},
        "deliverables": {"$ref": "#/$defs/stringArray"},
        "acceptance_criteria": {"$ref": "#/$defs/stringArray"},
        "verification": {"$ref": "#/$defs/stringArray"},
        "stop_conditions": {"$ref": "#/$defs/stringArray"},
        "depends_on": {"type": "array", "items": {"type": "string"}},
        "requirements": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/requirement"}}
      }
    },
    "requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "text", "acceptance_test"],
      "properties": {
        "id": {"type": "string", "pattern": "^REQ-[A-Z0-9-]+$"},
        "text": {"type": "string", "minLength": 1},
        "acceptance_test": {"type": "string", "minLength": 1}
      }
    }
  }
}
